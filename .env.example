# App
APP_ENV=development
APP_SECRET_KEY=your_secret_key_here
APP_PORT=8000
DEBUG=true

# Database — PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/banksaathi

# Cache — Redis
REDIS_URL=redis://localhost:6379/0

# WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=your_verify_token_here

# Sarvam AI
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_STT_ENDPOINT=https://api.sarvam.ai/speech-to-text
SARVAM_TTS_ENDPOINT=https://api.sarvam.ai/text-to-speech

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ChromaDB
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# LangGraph
LANGGRAPH_CHECKPOINT_DB=postgresql+psycopg://user:password@localhost:5432/banksaathi

# YONO Mock API (development only)
YONO_MOCK_BASE_URL=http://localhost:8002
YONO_MOCK_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
